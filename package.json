{
  "name": "mx-next-services",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:next\" \"npm run dev:server\"",
    "dev:next": "next dev",
    "dev:server": "nodemon server.ts",
    "build": "next build",
    "start": "NODE_ENV=production node dist/server.js",
    "build:server": "tsc --project tsconfig.server.json",
    "lint": "next lint",
    "prebuild": "npm run build:server",
    "vbridge:clean": "cd vBridge && find output -mindepth 1 -name '*.md' -prune -o -type f -delete && find output -mindepth 1 -type d -empty -delete",
    "vbridge:run": "cd vBridge && ./venv/bin/python3 scripts/vBridge.py",
    "vbridge:install": "cd vBridge && ./venv/bin/pip install -r requirements.txt",
    "vbridge:full": "npm run vbridge:clean && npm run vbridge:run"

  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.1.1",
    "next": "^15.0.0",
    "next-auth": "^4.24.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.4",
    "@types/react": "^18.2.42",
    "@types/react-dom": "^18.2.17",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "eslint-config-next": "^15.0.0",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3"
  }
}